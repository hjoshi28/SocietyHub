<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pre-register Visitor</title>
  <link rel="stylesheet" href="/css/new_visitor.css"> 
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

  <main class="container">
    <h1>Pre-register a New Visitor</h1>

    <form action="/resident/visitors/new" method="POST" class="visitor-form">
      
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="error-message"><%= error %></p>
      <% } %>

      <a href="/resident/visitors" class="back-link">
        &larr; Back to Visitor List
      </a>

      <div class="input-group">
        <label for="name">Visitor's Name:</label>
        <input type="text" id="name" name="name" required>
      </div>

      <div class="input-group">
        <label for="phone">Visitor's Phone:</label>
        <input type="tel" id="phone" name="phone" required placeholder="e.g., 555-123-4567">
      </div>

      <div class="input-group">
        <label for="expected_check_in">Expected Arrival Time:</label>
        <input type="datetime-local" id="expected_check_in" name="expected_check_in" required>
      </div>
      
      <button type="submit">Pre-register Visitor</button>
    </form>
  </main>

</body>
</html>