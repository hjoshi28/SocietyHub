<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Assigned Tasks</title>
    <link rel="stylesheet" href="/css/staff_complaints.css"> 
</head>
<body>

    <div class="container">
        <h1>My Assigned Complaints</h1>
        <a href="/staff/dashboard" class="back-link">&larr; Back to Dashboard</a>

        <div class="content-wrapper">
            <h2 class="section-title">My Tasks</h2>

            <% if (complaints.length === 0) { %>
                <p>You have no complaints assigned to you.</p>
            <% } else { %>
                <table class="content-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Flat</th>
                            <th>Resident</th>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% complaints.forEach(comp => { %>
                            <tr>
                                <td><%= new Date(comp.created_at).toLocaleDateString() %></td>
                                <td><%= comp.wing %>-<%= comp.flat_number %></td>
                                <td><%= comp.resident_name %></td>
                                <td><%= comp.title %></td>
                                <td><%= comp.description %></td>
                                <td class="status-<%= comp.status.replace(' ', '') %>">
                                    <%= comp.status %>
                                </td>
                                <td class="action-cell">
                                    <% if (comp.status === 'In Progress') { %>
                                        <form action="/staff/complaints/<%= comp.complaint_id %>/resolve" method="POST" style="display:inline;">
                                            <button type="submit" class="btn btn-success btn-small">Mark as Resolved</button>
                                        </form>
                                    <% } else { %>
                                        <span class="status-text-assigned">Completed</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>

        </div> </div> </body>
</html>
