<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visitor Management</title>
    <link rel="stylesheet" href="/css/staff_visitors.css"> 
</head>
<body>

    <div class="container">
        <h1>Security - Visitor Dashboard</h1>
        <a href="/staff/dashboard" class="back-link">&larr; Back to Dashboard</a>

        <div class="content-wrapper">

            <% if (typeof error !== 'undefined' && error) { %>
                <p class="error-message"><%= error %></p>
            <% } %>

            <div class="visitor-layout">
                
                <div class="visitor-col-form">
                    <div class="form-container">
                        <h2 class="section-title" style="margin-top: 0;">Register Walk-in</h2>
                        <form action="/staff/visitors/check-in" method="POST">
                            <div class="form-group">
                                <label for="name">Name:</label>
                                <input type="text" id="name" name="name" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone:</label>
                                <input type="text" id="phone" name="phone" required>
                            </div>
                            <div class="form-group">
                                <label for="flat_id">Flat to Visit:</label>
                                <select id="flat_id" name="flat_id" required>
                                    <option value="">-- Select Flat --</option>
                                    <% flats.forEach(flat => { %>
                                        <option value="<%= flat.flat_id %>">
                                            <%= flat.wing %> - <%= flat.flat_number %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary">Check-in Visitor</button>
                        </form>
                    </div>
                </div>

                <div class="visitor-col-tables">
                    <h2 class="section-title">Expected Visitors (Today)</h2>
                    <% if (preRegisteredVisitors.length === 0) { %>
                        <p>No pre-registered visitors for today.</p>
                    <% } else { %>
                        <table class="content-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Phone</th>
                                    <th>Expected</th>
                                    <th>Flat</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% preRegisteredVisitors.forEach(v => { %>
                                    <tr>
                                        <td><%= v.name %></td>
                                        <td><%= v.phone %></td>
                                        <td><%= new Date(v.expected_check_in).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></td>
                                        <td><%= v.wing %>-<%= v.flat_number %></td>
                                        <td class="action-cell">
                                            <form action="/staff/visitors/<%= v.visitor_id %>/check-in" method="POST">
                                                <button type="submit" class="btn btn-success btn-small">Check-in</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>

                    <h2 class="section-title" style="margin-top: 2rem;">Currently Checked-in Visitors</h2>
                    <% if (checkedInVisitors.length === 0) { %>
                        <p>No visitors currently in the society.</p>
                    <% } else { %>
                        <table class="content-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Phone</th>
                                    <th>Checked In</th>
                                    <th>Flat</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% checkedInVisitors.forEach(v => { %>
                                    <tr>
                                        <td><%= v.name %></td>
                                        <td><%= v.phone %></td>
                                        <td><%= new Date(v.actual_check_in).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></td>
                                        <td><%= v.wing %>-<%= v.flat_number %></td>
                                        <td class="action-cell">
                                            <form action="/staff/visitors/<%= v.visitor_id %>/check-out" method="POST">
                                                <button type="submit" class="btn btn-danger btn-small">Check-out</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div> </div> </div> </body>
</html>