<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Complaints</title>
    <link rel="stylesheet" href="/css/admin_complaints.css"> 
</head>
<body>

    <div class="container">
        <h1>Admin Complaint Dashboard</h1>
        <a href="/admin/dashboard" class="back-link">&larr; Back to Dashboard</a>

        <div class="content-wrapper">
            <h2 class="section-title">All Society Complaints</h2>

            <table class="content-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Flat</th>
                        <th>Resident</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% complaints.forEach(comp => { %>
                        <tr>
                            <td><%= new Date(comp.created_at).toLocaleDateString() %></td>
                            <td><%= comp.wing %>-<%= comp.flat_number %></td>
                            <td><%= comp.resident_name %></td>
                            <td><%= comp.title %></td>
                            <td class="status-<%= comp.status.replace(' ', '') %>">
                                <%= comp.status %>
                            </td>
                            <td><%= comp.staff_name || 'N/A' %></td>
                            <td class="action-cell">
                                <% if (comp.status === 'Pending') { %>
                                    <a href="/admin/complaints/<%= comp.complaint_id %>/assign" class="btn btn-primary btn-small">
                                        Assign
                                    </a>
                                <% } else { %>
                                    <span class="status-text-assigned">Assigned</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div> </div> </body>
</html>