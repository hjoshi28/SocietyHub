<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/profile_edit.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <title>Edit My Profile</title>
</head>
<body>

  <header class="main-header">
    <h1>Edit My Profile</h1>
    <a href="/resident/profile" class="header-link">Back to Profile</a>
  </header>

  <main class="container">

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="alert alert-danger"><%= error %></p>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
      <p class="alert alert-success"><%= success %></p>
    <% } %>

    <div class="profile-layout">
      
      <div class="card">
        <h3>Update Your Information</h3>
        <form action="/resident/profile/edit" method="POST">
          <div class="input-group">
            <label for="full_name">Full Name:</label>
            <input type="text" id="full_name" name="full_name" value="<%= user.name %>" required>
          </div>
          <div class="input-group">
            <label for="phone">Phone:</label>
            <input type="text" id="phone" name="phone" value="<%= user.phone %>" required>
          </div>
          <div class="input-group">
            <label for="email">Email (Read-only):</label>
            <input type="email" id="email" name="email" value="<%= user.email %>" readonly disabled>
          </div>
          <button type="submit">Save Changes</button>
        </form>
      </div>

      <div class="card">
        <h3>Change Your Password</h3>
        <form action="/resident/profile/change-password" method="POST">
          <div class="input-group">
            <label for="old_password">Old Password:</label>
            <input type="password" id="old_password" name="old_password" required>
          </div>
          <div class="input-group">
            <label for="new_password">New Password:</label>
            <input type="password" id="new_password" name="new_password" required>
          </div>
          <button type="submit">Change Password</button>
        </form>
      </div>

    </div> </main>

</body>
</html>