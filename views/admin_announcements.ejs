<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Announcements</title>
    <link rel="stylesheet" href="/css/admin_announcements.css"> 
</head>
<body>

    <div class="container">
        <h1>Admin - Manage Announcements</h1>
        <a href="/admin/dashboard" class="back-link">&larr; Back to Dashboard</a>

        <div class="content-wrapper">

            <div class="form-container">
                <h2>Post a New Announcement</h2>
                <form action="/admin/announcements" method="POST">
                    <div class="form-group">
                        <label for="title">Title:</label>
                        <input type="text" id="title" name="title" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="body">Body:</label>
                        <textarea id="body" name="body" rows="5" required></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Post Announcement</button>
                </form>
            </div>

            <h2 class="section-title">Posted Announcements</h2>

            <% if (announcements.length === 0) { %>
                <p>No announcements have been posted yet.</p>
            <% } else { %>
                <table class="content-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Title</th>
                            <th>Posted By</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% announcements.forEach(ann => { %>
                            <tr>
                                <td><%= new Date(ann.created_at).toLocaleDateString() %></td>
                                <td><%= ann.title %></td>
                                <td><%= ann.full_name %></td>
                                <td class="action-cell">
                                    <form action="/admin/announcements/<%= ann.announcement_id %>/delete" method="POST">
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>

        </div> </div> </body>
</html>