<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>File a New Complaint</title>
  <link rel="stylesheet" href="/css/new_complaint.css"> 
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

  <main class="container">
    <h1>File a New Complaint</h1>

    <form action="/resident/complaints/new" method="POST" class="complaint-form">
      
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="error-message"><%= error %></p>
      <% } %>

      <a href="/resident/complaints" class="back-link">
        &larr; Back to Complaint List
      </a>

      <div class="input-group">
        <label for="title">Subject:</label>
        <input type="text" id="title" name="title" required>
      </div>

      <div class="input-group">
        <label for="description">Description:</label>
        <textarea id="description" name="description" rows="5" required></textarea>
      </div>

      <button type="submit">Submit Complaint</button